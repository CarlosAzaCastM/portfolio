---
import "../assets/app.css";
import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

const {
  title,
  description = "Portfolio de Carlos Castañeda - Desarrollador Web",
  image = "/og-image.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={`${title} - Carlos Castañeda`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="generator" content={Astro.generator} />
    <title>{title} - Carlos Castañeda</title>

    <ClientRouter />
  </head>
  <body>
    <div class="drawer">
      <input id="main-menu-drawer" type="checkbox" class="drawer-toggle" />

      <div class="drawer-content flex flex-col min-h-screen">
        <Navbar />

        <main class="bg-black">
          <slot />
        </main>
      </div>

      <div class="drawer-side z-50">
        <label
          for="main-menu-drawer"
          aria-label="close sidebar"
          class="drawer-overlay"></label>
        <Sidebar />
      </div>
    </div>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background: #0e141b;
  }
</style>
