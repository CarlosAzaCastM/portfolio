---
import { navLinks } from "../data/menuItems";
---

<aside class="menu bg-base-200 min-h-full w-80 p-4">
  <h2 class="menu-title text-lg font-bold mb-4">Menu</h2>

  <nav>
    <ul>
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href}>{link.name}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>
