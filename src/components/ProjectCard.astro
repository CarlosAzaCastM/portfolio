---
import { MoveRight } from "lucide-react";

interface Props {
  title: string;
  imageSrc: string;
  imageAlt: string;
  description: string;
  projectUrl?: string;
  tags?: string[];
  canView?: boolean;
}

const {
  title,
  imageSrc,
  imageAlt,
  description,
  projectUrl,
  tags = [],
  canView = true,
} = Astro.props;
---

<article
  class="group relative bg-gradient-to-b from-white/10 to-white/5 border border-white/10 backdrop-blur-xl rounded-[36px] overflow-hidden transition-all duration-250 cursor-pointer hover:-translate-y-3 shadow-2xl hover:shadow-[#fa7474] hover:border-[#ff5277]/50 flex flex-col h-full"
>
  {/* Imagen del proyecto (Siempre visible) */}
  <div class="h-[280px] shrink-0 overflow-hidden">
    <img
      src={imageSrc}
      alt={imageAlt}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
  </div>

  <div class="p-9 flex flex-col flex-grow">
    {/* Tags (Opcionales, siempre visibles para darle contexto al título) */}
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5 ">
          {tags.map((tag) => (
            <span class="inline-block px-4 py-2 rounded-full bg-[#ff5277]/10 text-[#ff5277] border border-[#ff5277]/20 text-sm font-semibold">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    {/* Título (Siempre visible) */}
    <h3
      class="text-3xl font-bold group-hover:text-[#ff5277] transition-colors duration-300"
    >
      {title}
    </h3>

    {/* Sección expandible (Descripción y Tecnologías ocultas por defecto) */}
    <div
      class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] group-hover:opacity-100 transition-all duration-500 ease-in-out"
    >
      <div class="overflow-hidden">
        {
          /* Un poco de margen superior para separar del título cuando se expande */
        }
        <p class="text-[#e5e5e5] leading-relaxed mb-8 mt-4">
          {description}
        </p>

        <div class="flex flex-wrap gap-3 mb-8">
          {
            /* Aquí se renderizarán los TechBadge o spans que pases dentro del componente */
          }
          <slot />
        </div>
      </div>
    </div>

    {
      /* Enlace al proyecto (Siempre visible, empujado hacia abajo si es necesario) */
    }
    <div class="mt-auto pt-4">
      {
        canView && (
          <a
            target="_blank"
            href={projectUrl}
            class="inline-flex items-center gap-2.5 text-white font-semibold transition-all duration-150 hover:text-[#ff3460] hover:gap-4"
          >
            View <MoveRight className="transition-transform duration-150" />
          </a>
        )
      }
    </div>
  </div>
</article>
